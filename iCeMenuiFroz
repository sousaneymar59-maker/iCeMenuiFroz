-- TAB VISUAL
local VisualTab = Window:CreateTab("Visual", 4483362458)

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local AimEnabled = false
local AimStrength = 50
local TargetZone = "Head"
local TeamCheck = true
local VisibleCheck = true

local function getTarget()

	local closest = nil
	local dist = math.huge

	for _,player in pairs(Players:GetPlayers()) do

		if player ~= LocalPlayer and player.Character then

			if TeamCheck and player.Team == LocalPlayer.Team then
				continue
			end

			local char = player.Character

			local part

			if TargetZone == "Head" then
				part = char:FindFirstChild("Head")
			elseif TargetZone == "Torso" then
				part = char:FindFirstChild("HumanoidRootPart")
			else
				part = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
			end

			if part then

				local screen,visible = Camera:WorldToViewportPoint(part.Position)

				if visible then

					local mouse = game:GetService("UserInputService"):GetMouseLocation()

					local mag = (Vector2.new(screen.X,screen.Y) - mouse).Magnitude

					if mag < dist then
						dist = mag
						closest = part
					end

				end

			end

		end

	end

	return closest

end

RunService.RenderStepped:Connect(function()

	if not AimEnabled then return end

	local target = getTarget()

	if target then

		local cf = Camera.CFrame
		local new = CFrame.new(cf.Position,target.Position)

		Camera.CFrame = cf:Lerp(new,AimStrength/100)

	end

end)

