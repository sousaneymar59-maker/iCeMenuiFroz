local Crosshair2 = Drawing.new("Line")

-- FUNÇÃO VISIBILIDADE
local function isVisible(part)
	if not VisibilityCheck then return true end
	
	local origin = Camera.CFrame.Position
	local direction = (part.Position - origin)
	
	local params = RaycastParams.new()
	params.FilterDescendantsInstances = {LocalPlayer.Character}
	params.FilterType = Enum.RaycastFilterType.Blacklist
	
	local result = workspace:Raycast(origin, direction, params)
	
	if result and result.Instance and not result.Instance:IsDescendantOf(part.Parent) then
		return false
	end
	
	return true
end

-- PEGAR ALVO
local function getTarget()

	local closest = nil
	local shortest = FOVSize
	
	for _,player in pairs(Players:GetPlayers()) do
		
		if player ~= LocalPlayer and player.Character then
			
			if TeamCheck and player.Team == LocalPlayer.Team then
				continue
			end
			
			local part
			
			if TargetZone == "Head" then
				part = player.Character:FindFirstChild("Head")
			elseif TargetZone == "Torso" then
				part = player.Character:FindFirstChild("HumanoidRootPart")
			else
				part = player.Character:FindFirstChild("Head") or player.Character:FindFirstChild("HumanoidRootPart")
			end
			
			if part and IceVisibleCheck(part) then
				
				local screen,visible = Camera:WorldToViewportPoint(part.Position)
				
				if visible then
					
					local mouse = UIS:GetMouseLocation()
					local dist = (Vector2.new(screen.X,screen.Y) - mouse).Magnitude
					
					if dist < shortest then
						shortest = dist
						closest = part
					end
					
				end
				
			end
			
		end
		
	end
	
	return closest
end

-- LOOP PRINCIPAL
RunService.RenderStepped:Connect(function()

	local mouse = UIS:GetMouseLocation()

	-- FOV
	FOVCircle.Visible = ShowFOV
	FOVCircle.Radius = FOVSize
	FOVCircle.Thickness = FOVThickness
	FOVCircle.Position = mouse

	if FOVMode == "Static" then
		FOVCircle.Color = FOVColor
	end

	-- CROSSHAIR
	if CrosshairEnabled then
		
		Crosshair1.Visible = true
		Crosshair2.Visible = true
		
		Crosshair1.Color = CrosshairColor
		Crosshair2.Color = CrosshairColor
		
		Crosshair1.Thickness = CrosshairThickness
		Crosshair2.Thickness = CrosshairThickness
		
		Crosshair1.From = Vector2.new(mouse.X - CrosshairSize, mouse.Y)
		Crosshair1.To = Vector2.new(mouse.X + CrosshairSize, mouse.Y)
		
		Crosshair2.From = Vector2.new(mouse.X, mouse.Y - CrosshairSize)
		Crosshair2.To = Vector2.new(mouse.X, mouse.Y + CrosshairSize)
		
	else
		
		Crosshair1.Visible = false
		Crosshair2.Visible = false
		
	end

	-- AIM ASSIST
	if AimEnabled and TrainingMode then
		
		local target = getTarget()
		
		if target then
			
			local cf = Camera.CFrame
			local new = CFrame.new(cf.Position,target.Position)
			
			Camera.CFrame = cf:Lerp(new,AssistStrength/100)
			
		end
		
	end

end)

